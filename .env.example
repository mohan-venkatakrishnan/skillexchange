# Skill Exchange environment — copy to .env and fill in.
# Mirrors LaunchPad/PeerReview's stack (AWS Cognito + API Gateway + Lambda + DynamoDB + Amplify Hosting).
# NOTE: every VITE_* value is embedded in the shipped JS and is PUBLIC.
# Secrets (AWS keys, Google client secret, Razorpay/Stripe keys) are used by
# Terraform/Lambda only and never reach the frontend bundle.

# --- AWS (Terraform / deploy scripts only — never shipped) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# --- Google OAuth (pasted into Cognito via Terraform — never shipped) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Razorpay (launch payment provider — webhook Lambda only) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Stripe Connect (follow-up migration once India approval lands — webhook Lambda only) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- GitHub (Amplify git-connected CI/CD needs Webhooks scope on this token) ---
GITHUB_USERNAME=
GITHUB_REPO=
GITHUB_TOKEN=

# --- Superadmin (QA-only static login — hardcoded check in a Lambda authorizer, not a Cognito user) ---
SUPERADMIN_USERNAME=
SUPERADMIN_PASSWORD=

# --- Alert email ---
ALERT_EMAIL=

# --- Frontend (public by design, LaunchPad/PeerReview naming convention) ---
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
VITE_API_URL=
VITE_SITE_URL=https://skillexchange.tapdot.org

# --- Environment-specific (each Amplify branch gets its own values) ---
# main branch → prod table/bucket/domain; qa branch → qa table/bucket/domain.
DYNAMODB_TABLE=SkillExchange-qa
SKILLS_BUCKET=
AMPLIFY_APP_ID=

# true = run against a local mock data file with no backend (useful before AWS is provisioned)
VITE_USE_MOCK=true

# --- Test user (used by CI regression suite, mirrors LaunchPad's TEST_USER_* pattern) ---
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
